        "text": "肉 が 香 ば し く て お い し い 。いつ も すごい に す み ま し た 。 o n or i et の",
        "speaker_id": 0,
        "speaker_name": "Speaker 0",
        "start": 48.06358790397644,
        "end": 62.46358790397644
      },
      {
        "id": "7ac05a8b-1a6f-4054-a75c-fafa36d59d77",
        "text": "そうだね、火がついてるね。",
        "speaker_id": 0,
        "speaker_name": "Speaker 0",
        "start": 71.7544174194336,
        "end": 73.19441741943359
      },
      {
        "id": "1f336cc3-d444-4b85-aef6-ca4d1c6679fb",
        "text": "なの",
        "speaker_id": 0,
        "speaker_name": "Speaker 0",
        "start": 152.97140789031982,
        "end": 153.29140789031985
      },
      {
        "id": "33132572-1f8a-42bb-86d0-7b92134a375c",
        "text": "アヤ ちゃん、かわくん違う ね、チキンするか",
        "speaker_id": 0,
        "speaker_name": "Speaker 0",
        "start": 157.01140785217285,
        "end": 168.5658521461488
      }
    ]
